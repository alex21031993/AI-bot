# Crypto Intelligence Agent - Environment Configuration
# Copy this file to .env and fill in your values

# ============================================
# TELEGRAM CONFIGURATION
# ============================================

# Get this from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Admin user IDs (comma-separated)
# Get your ID using @userinfobot
ADMIN_USER_IDS=123456789

# Admin password (for admin panel access)
# REQUIRED - set this to secure password
ADMIN_PASSWORD=change_this_password


# ============================================
# USDT PAYMENT CONFIGURATION (TRC20)
# ============================================

# USDT TRC20 Contract Address (Official USDT on TRON)
# DO NOT CHANGE - This is the official USDT contract
USDT_CONTRACT_TRC20=TR7NHqjeKQxGTCi8q8REbdNKR2AfZ7Tn7

# Deposit TRON Address (Where users send USDT for payments)
TRON_DEPOSIT_ADDRESS=TCSYEiTBp67GvUk3f2f1foL1jdRKu6upD8

# Minimum payment confirmations (6 is standard for TRON)
MIN_CONFIRMATIONS=6

# Demo mode - true for testing (uses simulated whale data only)
# Базовые API (CoinGecko, Reddit) работают БЕСПЛАТНО без ключей
# Платные API (Whale Alert, CoinMarketCap) требуют ключей для расширенных функций
DEMO_MODE=true


# ============================================
# API KEYS (Optional - for enhanced features)
# ============================================

# CoinGecko API (free tier available)
# https://www.coingecko.com/en/api
COINGECKO_API_KEY=

# Whale Alert API
# https://whale-alert.io/
WHALE_ALERT_API_KEY=

# CoinMarketCap API
# https://coinmarketcap.com/api/
COINMARKETCAP_API_KEY=


# ============================================
# DATABASE CONFIGURATION
# ============================================

# SQLite database path (default)
DATABASE_PATH=subscriptions.db


# ============================================
# LOGGING
# ============================================

LOG_LEVEL=INFO
LOG_FILE=logs/crypto_agent.log
